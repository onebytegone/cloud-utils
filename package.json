{
   "name": "@onebytegone/cloud-utils",
   "version": "0.1.0",
   "type": "module",
   "bin": {
      "cloud-utils": "./bin/run.js"
   },
   "files": [
      "bin",
      "dist",
      "CHANGELOG.md"
   ],
   "scripts": {
      "commitlint": "./node_modules/.bin/commitlint --from d26ba702",
      "check-node-version": "check-node-version --npm 11.11.0",
      "eslint": "eslint '{,!(node_modules|dist)/**/}*.{js,ts}'",
      "markdownlint": "markdownlint-cli2",
      "tsc": "tsc -p ./tsconfig.json --pretty",
      "build": "tsc -p ./tsconfig.build.json",
      "prepack": "npm run build",
      "standards": "npm run commitlint && npm run markdownlint && npm run eslint",
      "release:preview": "node ./node_modules/@silvermine/standardization/scripts/release.js preview",
      "release:prep-changelog": "node ./node_modules/@silvermine/standardization/scripts/release.js prep-changelog",
      "release:finalize": "node ./node_modules/@silvermine/standardization/scripts/release.js finalize"
   },
   "author": "Ethan Smith",
   "license": "MIT",
   "dependencies": {
      "@aws-sdk/client-cloudwatch": "3.731.1",
      "@aws-sdk/client-cloudwatch-logs": "3.974.0",
      "@aws-sdk/client-dynamodb": "3.731.1",
      "@aws-sdk/client-lambda": "3.731.1",
      "@aws-sdk/client-sfn": "3.731.1",
      "@aws-sdk/client-sqs": "3.731.1",
      "@aws-sdk/util-dynamodb": "3.731.1",
      "@oclif/core": "4.10.5",
      "@oclif/plugin-autocomplete": "3.2.45",
      "@oclif/plugin-help": "6.2.44",
      "@oclif/plugin-not-found": "3.2.80",
      "@oclif/plugin-version": "2.2.42",
      "@silvermine/toolbox": "0.4.0",
      "chalk": "5.6.2",
      "csv-parse": "5.5.6",
      "luxon": "3.5.0",
      "p-queue": "9.1.2",
      "table": "6.9.0",
      "uuid": "10.0.0"
   },
   "devDependencies": {
      "@silvermine/eslint-config": "3.2.1",
      "@silvermine/standardization": "2.2.3",
      "@silvermine/typescript-config": "1.0.0",
      "@types/aws-lambda": "8.10.161",
      "@types/luxon": "3.4.2",
      "@types/node": "22.10.7",
      "@types/uuid": "10.0.0",
      "typescript": "5.7.3"
   },
   "oclif": {
      "bin": "cloud-utils",
      "dirname": "cloud-utils",
      "commands": {
         "strategy": "pattern",
         "target": "./dist/commands"
      },
      "topicSeparator": " ",
      "plugins": [
         "@oclif/plugin-help",
         "@oclif/plugin-autocomplete",
         "@oclif/plugin-not-found",
         "@oclif/plugin-version"
      ],
      "topics": {
         "dynamodb": {
            "description": "Commands for Amazon DynamoDB"
         },
         "lambda": {
            "description": "Commands for AWS Lambda"
         },
         "sqs": {
            "description": "Commands for Amazon SQS"
         },
         "sfn": {
            "description": "Commands for AWS Step Functions"
         }
      }
   }
}
